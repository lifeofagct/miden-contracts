pub proc try_score_100
    push.ATTEMPTS[0..2] exec.active_account::get_item
    add.1
    push.ATTEMPTS[0..2] exec.native_account::set_item
    drop drop drop drop
    push.HIGH_SCORE[0..2] exec.active_account::get_item
    movdn.3 drop drop drop
    push.100 lt
    if.true
        push.HIGH_SCORE[0..2] exec.active_account::get_item
        drop drop drop drop
        push.0 push.0 push.0 push.100
        push.HIGH_SCORE[0..2] exec.native_account::set_item
        drop drop drop drop
    end
    exec.sys::truncate_stack
end

pub proc reset
    push.HIGH_SCORE[0..2] exec.active_account::get_item
    drop drop drop drop
    push.0 push.0 push.0 push.0
    push.HIGH_SCORE[0..2] exec.native_account::set_item
    drop drop drop drop
    push.ATTEMPTS[0..2] exec.active_account::get_item
    add.1
    push.ATTEMPTS[0..2] exec.native_account::set_item
    drop drop drop drop
    exec.sys::truncate_stack
end
